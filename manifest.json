{
  "manifest_version": 3,
  "name": "ChronoPanel",
  "short_name": "ChronoPanel",
  "description": "Local-only browser usage tracker with a calm daily dashboard.",
  "version": "1.0.0",
  "minimum_chrome_version": "114",
  "permissions": ["storage", "history", "sidePanel"],
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "ui/sidepanel.html"
  },
  "action": {
    "default_title": "Open ChronoPanel",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png"
    }
  }
}
